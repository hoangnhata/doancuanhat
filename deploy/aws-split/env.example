# Sao chép: sudo cp env.example /etc/expense-manager/production.env
# Chỉ BACKEND — MySQL dùng AWS RDS, AI dùng Hugging Face Space

# --- AWS RDS MySQL ---
SPRING_DATASOURCE_URL=jdbc:mysql://YOUR_RDS_ENDPOINT:3306/expense_manager?useSSL=true&serverTimezone=Asia/Ho_Chi_Minh&allowPublicKeyRetrieval=true&characterEncoding=UTF-8
SPRING_DATASOURCE_USERNAME=admin
SPRING_DATASOURCE_PASSWORD=CHANGE_ME_RDS_PASSWORD

# --- Spring Boot ---
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32
SPRING_PROFILES_ACTIVE=prod
SEED_DEMO_USER=false
PASSWORD_RESET_DEV_LOG_OTP=false
AI_CHAT_HISTORY_DAYS=45

# URL Hugging Face Space (không có dấu / cuối)
PYTHON_AI_API_URL=https://YOUR_USERNAME-expense-ai.hf.space

# CORS — thêm URL web Vercel, phân tách bằng dấu phẩy
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# Gmail App Password (OTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# --- Deploy ---
APP_DIR=/home/ubuntu/doancuanhat
APP_USER=ubuntu
GIT_REPO=https://github.com/hoangnhata/doancuanhat.git
