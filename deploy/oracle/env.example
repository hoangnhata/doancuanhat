# Sao chép thành /etc/expense-manager/production.env trên VM Oracle
#   sudo mkdir -p /etc/expense-manager
#   sudo cp env.example /etc/expense-manager/production.env
#   sudo nano /etc/expense-manager/production.env

# --- MySQL (setup.sh tạo user/db từ các biến này) ---
MYSQL_DATABASE=expense_manager
MYSQL_USER=expense
MYSQL_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- Spring Boot ---
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/expense_manager?useSSL=false&serverTimezone=Asia/Ho_Chi_Minh&allowPublicKeyRetrieval=true&characterEncoding=UTF-8
SPRING_DATASOURCE_USERNAME=expense
SPRING_DATASOURCE_PASSWORD=CHANGE_ME_STRONG_PASSWORD
JWT_SECRET=CHANGE_ME_RUN_openssl_rand_hex_32
SPRING_PROFILES_ACTIVE=prod

PYTHON_AI_API_URL=http://127.0.0.1:8000
SEED_DEMO_USER=false
PASSWORD_RESET_DEV_LOG_OTP=false
AI_CHAT_HISTORY_DAYS=45

# CORS: thêm URL web/app production, phân tách bằng dấu phẩy
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Gmail App Password (OTP đăng ký / quên mật khẩu)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# --- AI Service (Gemini chatbot — free tier) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_TIMEOUT_S=20

# --- Deploy ---
APP_DIR=/home/ubuntu/Doantotnghiep2
APP_USER=ubuntu
GIT_REPO=https://github.com/YOUR_USERNAME/Doantotnghiep2.git
